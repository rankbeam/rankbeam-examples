{
    "name": "rankbeam/example-blade",
    "type": "project",
    "description": "rankbeam-examples — Blade reference app proving the Rendering Contract on a classic server-rendered stack.",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "nesbot/carbon": "3.11.*",
        "rankbeam/laravel-seo": "^3.0@dev",
        "rankbeam/examples-shared": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "repositories": [
        { "type": "path", "url": "../../../laravel-seo", "options": { "symlink": true } },
        { "type": "path", "url": "../../packages/examples-shared", "options": { "symlink": true } }
    ],
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
