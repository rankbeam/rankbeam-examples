APP_NAME=Rankbeam
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8212
APP_LOCALE=en-US

LOG_CHANNEL=stack
DB_CONNECTION=sqlite

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# SEO config is driven entirely from env in this thin app (no published
# config/seo.php). These map to the contract fixtures' `config` block.
SEO_TWITTER_SITE=@rankbeam
SEO_DEFAULT_OG_IMAGE=/images/og-default.jpg
SEO_DEFAULT_ROBOTS=index,follow
SEO_AUTO_CREATE_META=false
