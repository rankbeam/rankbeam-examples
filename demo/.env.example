APP_NAME=Rankbeam
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
DB_CONNECTION=sqlite

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# SEO config is env-driven in this thin app (no published config/seo.php).
SEO_TWITTER_SITE=@rankbeam
SEO_DEFAULT_OG_IMAGE=/images/og-default.jpg
SEO_DEFAULT_ROBOTS=index,follow
SEO_AUTO_CREATE_META=false

# Pro (WITH_PRO build) is BYO-key AI — OFF by default; the demo audit needs no AI.
# SEO_PRO_AI_ENABLED=false
