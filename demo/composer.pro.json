{
    "name": "rankbeam/demo",
    "type": "project",
    "description": "Rankbeam SEO — runnable prospect demo on the released core + Pro (headless technical-SEO audit).",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "nesbot/carbon": "3.11.*",
        "rankbeam/laravel-seo": "^3.0",
        "rankbeam/laravel-seo-pro": "^2.0",
        "rankbeam/examples-shared": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "repositories": [
        { "type": "composer", "url": "https://laravel-seo-pro.composer.sh" },
        { "type": "path", "url": "/shared/examples-shared", "options": { "symlink": false } }
    ],
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
